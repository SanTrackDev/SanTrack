<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>SanTrack</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #428247;
    --green-dark: #2e5c32;
    --green-light: #54a55a;
    --yellow: #FFD100;
    --dark: #383838;
    --dark2: #2e2e2e;
    --dark3: #444444;
    --dark4: #555555;
    --text: #FFFFFF;
    --text2: #bbbbbb;
    --text3: #888888;
    --red: #F85149;
    --blue: #388BFD;
    --orange: #F0883E;
    --radius: 12px;
    --shadow: 0 4px 24px rgba(0,0,0,0.4);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Barlow', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .screen { display: none; min-height: 100vh; }
  .screen.active { display: flex; flex-direction: column; }

  #loginScreen {
    background: var(--dark);
    justify-content: center;
    align-items: center;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }

  .login-box {
    background: var(--dark2);
    border: 1px solid var(--dark4);
    border-radius: 20px;
    padding: 40px 32px;
    width: 100%;
    max-width: 400px;
    box-shadow: var(--shadow);
    position: relative;
    z-index: 1;
  }

  .logo { text-align: center; margin-bottom: 32px; }
  .logo h1 { font-family: 'Barlow Condensed', sans-serif; font-size: 28px; font-weight: 800; letter-spacing: 1px; color: var(--text); }
  .logo span { color: var(--green); }
  .logo p { color: var(--text2); font-size: 13px; margin-top: 4px; }

  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--text2); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
  .form-group input, .form-group select, .form-group textarea { width: 100%; background: var(--dark3); border: 1px solid var(--dark4); border-radius: var(--radius); padding: 12px 16px; color: var(--text); font-family: 'Barlow', sans-serif; font-size: 15px; outline: none; transition: border-color 0.2s; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--green); }
  .form-group select option { background: var(--dark3); }

  .btn { width: 100%; padding: 14px; border: none; border-radius: var(--radius); font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
  .btn-primary { background: var(--green); color: #fff; box-shadow: 0 4px 16px rgba(0,166,81,0.3); }
  .btn-primary:hover { background: var(--green-light); transform: translateY(-1px); }
  .btn-danger { background: var(--red); color: #fff; }

  .auth-toggle { text-align: center; margin-top: 20px; font-size: 14px; color: var(--text2); }
  .auth-toggle a { color: var(--green); cursor: pointer; text-decoration: none; font-weight: 600; }

  .app-header { background: var(--dark2); border-bottom: 1px solid var(--dark3); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
  .header-logo { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; letter-spacing: 1px; }
  .header-logo span { color: var(--green); }
  .avatar { width: 36px; height: 36px; background: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 15px; color: #fff; }
  .logout-btn { background: none; border: none; color: var(--text2); cursor: pointer; font-size: 20px; padding: 4px; transition: color 0.2s; }
  .logout-btn:hover { color: var(--red); }

  .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--dark2); border-top: 1px solid var(--dark3); display: flex; z-index: 100; padding-bottom: env(safe-area-inset-bottom); }
  .nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 10px 4px; cursor: pointer; transition: all 0.2s; color: var(--text3); border: none; background: none; font-family: 'Barlow', sans-serif; }
  .nav-item.active { color: var(--green); }
  .nav-item span { font-size: 20px; margin-bottom: 2px; }
  .nav-item p { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }

  .main-content { flex: 1; padding: 20px; padding-bottom: 80px; overflow-y: auto; }
  .page { display: none; }
  .page.active { display: block; }

  .card { background: var(--dark2); border: 1px solid var(--dark3); border-radius: var(--radius); padding: 20px; margin-bottom: 16px; }
  .card-title { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text2); margin-bottom: 8px; }
  .card-value { font-family: 'Barlow Condensed', sans-serif; font-size: 36px; font-weight: 800; color: var(--text); }
  .card-value.green { color: var(--green); }
  .card-value.yellow { color: var(--yellow); }
  .card-sub { font-size: 13px; color: var(--text2); margin-top: 4px; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

  .section-title { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 800; letter-spacing: 0.5px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
  .section-title .badge { background: var(--green); color: #fff; font-size: 11px; padding: 2px 8px; border-radius: 20px; font-weight: 700; }

  .shift-item { background: var(--dark3); border: 1px solid var(--dark4); border-radius: var(--radius); padding: 16px; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; }
  .shift-left { display: flex; flex-direction: column; gap: 4px; }
  .shift-date { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; }
  .shift-hours { font-size: 13px; color: var(--text2); }
  .shift-pay { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; color: var(--green); }
  .tag { display: inline-block; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .tag-regular { background: rgba(56,139,253,0.2); color: var(--blue); }
  .tag-overtime { background: rgba(255,209,0,0.2); color: var(--yellow); }
  .tag-holiday { background: rgba(248,81,73,0.2); color: var(--red); }
  .tag-differential { background: rgba(240,136,62,0.2); color: var(--orange); }

  .cal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .cal-nav { background: var(--dark3); border: 1px solid var(--dark4); border-radius: 8px; color: var(--text); font-size: 18px; cursor: pointer; padding: 6px 12px; }
  .cal-month { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .cal-day-name { text-align: center; font-size: 11px; font-weight: 700; color: var(--text3); text-transform: uppercase; padding: 4px 0; }
  .cal-day { aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 0.15s; position: relative; }
  .cal-day:hover { background: var(--dark3); }
  .cal-day.empty { cursor: default; }
  .cal-day.today { background: rgba(66,130,71,0.2); color: var(--green); font-weight: 800; }
  .cal-day.has-shift::after { content: ''; position: absolute; bottom: 3px; width: 4px; height: 4px; border-radius: 50%; background: var(--green); }
  .cal-day.ot::after { background: var(--yellow); }
  .cal-day.holiday::after { background: var(--red); }

  .task-item { background: var(--dark3); border: 1px solid var(--dark4); border-radius: var(--radius); padding: 14px 16px; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
  .task-check { width: 22px; height: 22px; border: 2px solid var(--dark4); border-radius: 6px; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
  .task-check.done { background: var(--green); border-color: var(--green); }
  .task-text { flex: 1; font-size: 15px; }
  .task-text.done { text-decoration: line-through; color: var(--text2); }
  .delete-btn { background: none; border: none; color: var(--text3); cursor: pointer; font-size: 16px; padding: 4px; transition: color 0.2s; }
  .delete-btn:hover { color: var(--red); }

  .pay-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--dark3); font-size: 15px; }
  .pay-row:last-child { border-bottom: none; }
  .pay-row .label { color: var(--text2); }
  .pay-row .amount { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; }
  .pay-total { background: linear-gradient(135deg, rgba(66,130,71,0.15), rgba(66,130,71,0.05)); border: 1px solid rgba(66,130,71,0.3); border-radius: var(--radius); padding: 16px; margin-top: 12px; display: flex; justify-content: space-between; align-items: center; }
  .pay-total .label { font-family: 'Barlow Condensed', sans-serif; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--green); }
  .pay-total .amount { font-family: 'Barlow Condensed', sans-serif; font-size: 32px; font-weight: 800; color: var(--green); }

  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 200; align-items: flex-end; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--dark2); border: 1px solid var(--dark3); border-radius: 20px 20px 0 0; padding: 24px; width: 100%; max-width: 500px; max-height: 90vh; overflow-y: auto; }
  .modal-title { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
  .close-btn { background: none; border: none; color: var(--text2); font-size: 22px; cursor: pointer; }

  .toast { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--dark3); border: 1px solid var(--green); border-radius: 100px; padding: 10px 20px; font-size: 14px; font-weight: 600; color: var(--green); opacity: 0; transition: all 0.3s; z-index: 300; white-space: nowrap; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  .fab { position: fixed; bottom: 80px; right: 20px; width: 52px; height: 52px; background: var(--green); border: none; border-radius: 50%; font-size: 24px; color: #fff; cursor: pointer; box-shadow: 0 4px 16px rgba(66,130,71,0.4); display: flex; align-items: center; justify-content: center; z-index: 99; transition: all 0.2s; }
  .fab:hover { transform: scale(1.1); }

  .alert { background: rgba(248,81,73,0.1); border: 1px solid rgba(248,81,73,0.3); border-radius: var(--radius); padding: 12px 16px; font-size: 13px; color: var(--red); margin-bottom: 16px; }
  .empty-state { text-align: center; padding: 40px 20px; color: var(--text2); }
  .empty-state .icon { font-size: 40px; margin-bottom: 12px; }
  .empty-state p { font-size: 14px; }
  .pay-rate-info { font-size: 12px; color: var(--text3); margin-top: 4px; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .page.active { animation: fadeIn 0.25s ease; }

  .profile-section { display: flex; align-items: center; gap: 16px; padding: 20px; background: var(--dark2); border: 1px solid var(--dark3); border-radius: var(--radius); margin-bottom: 16px; }
  .profile-avatar { width: 60px; height: 60px; background: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-size: 24px; font-weight: 800; color: #fff; flex-shrink: 0; }
  .profile-info h2 { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; }
  .profile-info p { font-size: 13px; color: var(--text2); margin-top: 2px; }

  .settings-row { display: flex; align-items: center; justify-content: space-between; padding: 14px 0; border-bottom: 1px solid var(--dark3); font-size: 15px; }
  .settings-row:last-child { border-bottom: none; }
  .settings-row .label { color: var(--text2); font-size: 13px; }
  .settings-row .value { font-weight: 600; font-size: 14px; }
</style>
</head>
<body>

<div id="loginScreen" class="screen active">
  <div class="login-box">
    <div class="logo">
      <h1>San<span>Track</span></h1>
      <p>NYC Department of Sanitation</p>
    </div>
    <div id="loginError" class="alert" style="display:none"></div>
    <div id="loginForm">
      <div class="form-group">
        <label>Email</label>
        <input type="email" id="loginId" placeholder="you@email.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" id="loginPass" placeholder="••••••••" autocomplete="current-password">
      </div>
      <button class="btn btn-primary" onclick="login()">Sign In</button>
      <div class="auth-toggle">Don't have an account? <a onclick="showRegister()">Register</a></div>
    </div>
    <div id="registerForm" style="display:none">
      <div class="form-group"><label>Full Name</label><input type="text" id="regName" placeholder="John Smith"></div>
      <div class="form-group"><label>Email</label><input type="email" id="regId" placeholder="you@email.com"></div>
      <div class="form-group">
        <label>District / Section</label>
        <select id="regDistrict">
          <option value="">Select your district</option>
          <option>Brooklyn North - BKN</option>
          <option>Brooklyn South - BKS</option>
          <option>Bronx - BX</option>
          <option>Manhattan - MN</option>
          <option>Queens East - QNE</option>
          <option>Queens West - QNW</option>
          <option>Staten Island - SI</option>
        </select>
      </div>
      <div class="form-group">
        <label>Title / Rank</label>
        <select id="regTitle">
          <option value="">Select title</option>
          <option>Sanitation Worker</option>
          <option>Supervisor</option>
          <option>Foreman</option>
          <option>Section Supervisor</option>
          <option>Superintendent</option>
        </select>
      </div>
      <div class="form-group"><label>Hourly Rate ($)</label><input type="number" id="regRate" placeholder="e.g. 35.00" step="0.01"></div>
      <div class="form-group"><label>Password</label><input type="password" id="regPass" placeholder="Create a password"></div>
      <button class="btn btn-primary" onclick="register()">Create Account</button>
      <div class="auth-toggle">Already have an account? <a onclick="showLogin()">Sign In</a></div>
    </div>
  </div>
</div>

<div id="appScreen" class="screen">
  <div class="app-header">
    <div class="header-logo">San<span>Track</span></div>
    <div style="display:flex;align-items:center;gap:10px">
      <div class="avatar" id="headerAvatar">JD</div>
      <button class="logout-btn" onclick="logout()">⏻</button>
    </div>
  </div>

  <div class="main-content">
    <div id="dashPage" class="page active">
      <div class="section-title" id="dashGreeting">Good morning 👋</div>
      <div class="grid-2" style="margin-bottom:12px">
        <div class="card"><div class="card-title">This Week</div><div class="card-value green" id="weekHours">0h</div><div class="card-sub" id="weekOT">0h overtime</div></div>
        <div class="card"><div class="card-title">This Week Pay</div><div class="card-value yellow" id="weekPay">$0</div><div class="card-sub">est. gross</div></div>
      </div>
      <div class="grid-3" style="margin-bottom:16px">
        <div class="card" style="padding:14px"><div class="card-title" style="font-size:11px">Month Hours</div><div class="card-value" style="font-size:24px" id="monthHours">0h</div></div>
        <div class="card" style="padding:14px"><div class="card-title" style="font-size:11px">Month Pay</div><div class="card-value green" style="font-size:24px" id="monthPay">$0</div></div>
        <div class="card" style="padding:14px"><div class="card-title" style="font-size:11px">Shifts</div><div class="card-value" style="font-size:24px" id="monthShifts">0</div></div>
      </div>
      <div class="section-title">Recent Shifts</div>
      <div id="recentShifts"><div class="empty-state"><div class="icon">📋</div><p>No shifts logged yet. Tap + to add your first shift.</p></div></div>
    </div>

    <div id="shiftsPage" class="page">
      <div class="section-title">My Shifts <span class="badge" id="shiftCount">0</span></div>
      <div id="shiftsList"><div class="empty-state"><div class="icon">🕐</div><p>No shifts yet. Tap + to log a shift.</p></div></div>
    </div>

    <div id="payPage" class="page">
      <div class="section-title">Pay Summary</div>
      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Pay Period</div>
        <select id="payPeriodSelect" onchange="updatePayPage()" style="background:var(--dark3);border:1px solid var(--dark4);border-radius:8px;padding:8px 12px;color:var(--text);font-family:Barlow,sans-serif;font-size:14px;width:100%;outline:none;margin-top:4px;">
          <option value="week">This Week</option>
          <option value="month">This Month</option>
          <option value="year">This Year</option>
          <option value="all">All Time</option>
        </select>
      </div>
      <div class="card">
        <div class="card-title">Breakdown</div>
        <div class="pay-row"><span class="label">Regular Hours</span><span class="amount" id="payRegHours">0h</span></div>
        <div class="pay-row"><span class="label">Regular Pay</span><span class="amount" id="payRegPay">$0.00</span></div>
        <div class="pay-row"><span class="label">Overtime Hours</span><span class="amount yellow" id="payOTHours">0h</span></div>
        <div class="pay-row"><span class="label">Overtime Pay (1.5x)</span><span class="amount yellow" id="payOTPay">$0.00</span></div>
        <div class="pay-row"><span class="label">Holiday Pay (2x)</span><span class="amount" style="color:var(--red)" id="payHolidayPay">$0.00</span></div>
        <div class="pay-row"><span class="label">Night Differential</span><span class="amount" style="color:var(--orange)" id="payDiffPay">$0.00</span></div>
        <div class="pay-row"><span class="label">Uniform Allowance</span><span class="amount" id="payUniform">$0.00</span></div>
        <div class="pay-total"><span class="label">Estimated Gross</span><span class="amount" id="payTotal">$0.00</span></div>
      </div>
      <div class="card">
        <div class="card-title">Your Base Rate</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800" id="baseRateDisplay">$0.00/hr</div>
        <div class="pay-rate-info">OT Rate: <span id="otRateDisplay">$0.00</span>/hr &nbsp;|&nbsp; Holiday Rate: <span id="holidayRateDisplay">$0.00</span>/hr</div>
      </div>
    </div>

    <div id="calPage" class="page">
      <div class="card">
        <div class="cal-header">
          <button class="cal-nav" onclick="prevMonth()">‹</button>
          <div class="cal-month" id="calMonth">March 2026</div>
          <button class="cal-nav" onclick="nextMonth()">›</button>
        </div>
        <div class="cal-grid" id="calGrid"></div>
      </div>
      <div id="calDayDetail" style="display:none">
        <div class="section-title" id="calDayTitle"></div>
        <div id="calDayShifts"></div>
      </div>
    </div>

    <div id="tasksPage" class="page">
      <div class="section-title">Tasks & Notes <span class="badge" id="taskCount">0</span></div>
      <div id="tasksList"><div class="empty-state"><div class="icon">✅</div><p>No tasks yet. Tap + to add one.</p></div></div>
    </div>

    <div id="profilePage" class="page">
      <div class="profile-section">
        <div class="profile-avatar" id="profileAvatar">JD</div>
        <div class="profile-info">
          <h2 id="profileName">John Doe</h2>
          <p id="profileDistrict">District</p>
          <p id="profileTitle">Title</p>
        </div>
      </div>
      <div class="section-title">Settings</div>
      <div class="card">
        <div class="settings-row"><div><div>Email</div><div class="label">Your login email</div></div><div class="value" id="profileId">—</div></div>
        <div class="settings-row"><div><div>Base Hourly Rate</div><div class="label">Regular pay rate</div></div><div class="value" id="profileRate">—</div></div>
        <div class="settings-row"><div><div>Uniform Allowance</div><div class="label">Annual amount</div></div><div class="value" id="profileUniform">$1,200/yr</div></div>
        <div class="settings-row"><div><div>Total Shifts Logged</div><div class="label">All time</div></div><div class="value" id="profileShiftTotal">0</div></div>
      </div>
      <div class="form-group" style="margin-top:8px"><label>Update Hourly Rate ($)</label><input type="number" id="updateRate" placeholder="New rate" step="0.01"></div>
      <button class="btn btn-primary" style="margin-bottom:12px" onclick="updateRate()">Update Rate</button>
      <button class="btn btn-danger" onclick="logout()">Sign Out</button>
    </div>
  </div>

  <nav class="bottom-nav">
    <button class="nav-item active" onclick="showPage('dash')" id="nav-dash"><span>🏠</span><p>Home</p></button>
    <button class="nav-item" onclick="showPage('shifts')" id="nav-shifts"><span>🕐</span><p>Shifts</p></button>
    <button class="nav-item" onclick="showPage('pay')" id="nav-pay"><span>💵</span><p>Pay</p></button>
    <button class="nav-item" onclick="showPage('cal')" id="nav-cal"><span>📅</span><p>Calendar</p></button>
    <button class="nav-item" onclick="showPage('tasks')" id="nav-tasks"><span>✅</span><p>Tasks</p></button>
    <button class="nav-item" onclick="showPage('profile')" id="nav-profile"><span>👤</span><p>Profile</p></button>
  </nav>
</div>

<button class="fab" id="fab" onclick="openFab()">+</button>

<div class="modal-overlay" id="shiftModal">
  <div class="modal">
    <div class="modal-title">Log Shift <button class="close-btn" onclick="closeModal('shiftModal')">✕</button></div>
    <div class="form-group"><label>Date</label><input type="date" id="shiftDate"></div>
    <div class="form-group"><label>Shift Type</label>
      <select id="shiftType">
        <option value="regular">Regular</option>
        <option value="overtime">Overtime</option>
        <option value="holiday">Holiday</option>
        <option value="differential">Night Differential</option>
      </select>
    </div>
    <div class="form-group"><label>Start Time</label><input type="time" id="shiftStart"></div>
    <div class="form-group"><label>End Time</label><input type="time" id="shiftEnd"></div>
    <div class="form-group"><label>Route / Assignment (optional)</label><input type="text" id="shiftRoute" placeholder="e.g. Route 14 - Collection"></div>
    <div class="form-group"><label>Notes (optional)</label><textarea id="shiftNotes" rows="2" placeholder="Any notes..."></textarea></div>
    <button class="btn btn-primary" onclick="addShift()">Log Shift</button>
  </div>
</div>

<div class="modal-overlay" id="taskModal">
  <div class="modal">
    <div class="modal-title">Add Task <button class="close-btn" onclick="closeModal('taskModal')">✕</button></div>
    <div class="form-group"><label>Task</label><input type="text" id="taskText" placeholder="What needs to be done?"></div>
    <div class="form-group"><label>Priority</label>
      <select id="taskPriority">
        <option value="🔴">🔴 High</option>
        <option value="🟡" selected>🟡 Medium</option>
        <option value="🟢">🟢 Low</option>
      </select>
    </div>
    <div class="form-group"><label>Due Date (optional)</label><input type="date" id="taskDue"></div>
    <button class="btn btn-primary" onclick="addTask()">Add Task</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let currentUser = null;
let currentPage = 'dash';
let calDate = new Date();

function getUsers() { try { return JSON.parse(localStorage.getItem('dsny_users') || '{}'); } catch(e) { return {}; } }
function saveUsers(u) { localStorage.setItem('dsny_users', JSON.stringify(u)); }
function getUserData(id) { try { return JSON.parse(localStorage.getItem('dsny_data_' + id) || '{"shifts":[],"tasks":[]}'); } catch(e) { return {shifts:[], tasks:[]}; } }
function saveUserData(id, d) { localStorage.setItem('dsny_data_' + id, JSON.stringify(d)); }

function showRegister() { document.getElementById('loginForm').style.display='none'; document.getElementById('registerForm').style.display='block'; document.getElementById('loginError').style.display='none'; }
function showLogin() { document.getElementById('loginForm').style.display='block'; document.getElementById('registerForm').style.display='none'; document.getElementById('loginError').style.display='none'; }

function register() {
  const name=document.getElementById('regName').value.trim();
  const id=document.getElementById('regId').value.trim().toLowerCase();
  const district=document.getElementById('regDistrict').value;
  const title=document.getElementById('regTitle').value;
  const rate=parseFloat(document.getElementById('regRate').value);
  const pass=document.getElementById('regPass').value;
  if (!name||!id||!district||!title||!rate||!pass) { showError('Please fill in all fields.'); return; }
  const users=getUsers();
  if (users[id]) { showError('Email already registered.'); return; }
  users[id]={name,id,district,title,rate,pass};
  saveUsers(users);
  showToast('Account created! Sign in now.');
  showLogin();
}

function login() {
  const id=document.getElementById('loginId').value.trim().toLowerCase();
  const pass=document.getElementById('loginPass').value;
  const users=getUsers();
  if (!users[id]||users[id].pass!==pass) { showError('Invalid email or password.'); return; }
  currentUser=users[id];
  localStorage.setItem('dsny_session',id);
  startApp();
}

function logout() {
  currentUser=null;
  localStorage.removeItem('dsny_session');
  document.getElementById('loginScreen').classList.add('active');
  document.getElementById('appScreen').classList.remove('active');
  document.getElementById('loginId').value='';
  document.getElementById('loginPass').value='';
}

function showError(msg) { const el=document.getElementById('loginError'); el.textContent=msg; el.style.display='block'; }

function startApp() {
  document.getElementById('loginScreen').classList.remove('active');
  document.getElementById('appScreen').classList.add('active');
  const initials=currentUser.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('headerAvatar').textContent=initials;
  document.getElementById('profileAvatar').textContent=initials;
  document.getElementById('profileName').textContent=currentUser.name;
  document.getElementById('profileDistrict').textContent=currentUser.district;
  document.getElementById('profileTitle').textContent=currentUser.title;
  document.getElementById('profileId').textContent=currentUser.id;
  document.getElementById('profileRate').textContent='$'+parseFloat(currentUser.rate).toFixed(2)+'/hr';
  document.getElementById('baseRateDisplay').textContent='$'+parseFloat(currentUser.rate).toFixed(2)+'/hr';
  document.getElementById('otRateDisplay').textContent='$'+(currentUser.rate*1.5).toFixed(2);
  document.getElementById('holidayRateDisplay').textContent='$'+(currentUser.rate*2).toFixed(2);
  const h=new Date().getHours();
  const greet=h<12?'Good morning':h<17?'Good afternoon':'Good evening';
  document.getElementById('dashGreeting').innerHTML=`${greet}, ${currentUser.name.split(' ')[0]} <span class="badge" style="font-size:14px">👋</span>`;
  showPage('dash'); renderCalendar(); refreshAll();
}

function showPage(page) {
  currentPage=page;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById(page+'Page').classList.add('active');
  document.getElementById('nav-'+page).classList.add('active');
  document.getElementById('fab').style.display=(page==='profile'||page==='pay')?'none':'flex';
  if (page==='cal') renderCalendar();
  if (page==='pay') updatePayPage();
}

function openFab() {
  if (currentPage==='tasks') { document.getElementById('taskModal').classList.add('open'); document.getElementById('taskText').focus(); }
  else { document.getElementById('shiftDate').value=new Date().toISOString().split('T')[0]; document.getElementById('shiftModal').classList.add('open'); }
}
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function calcHours(start,end) {
  const [sh,sm]=start.split(':').map(Number);
  const [eh,em]=end.split(':').map(Number);
  let mins=(eh*60+em)-(sh*60+sm);
  if (mins<0) mins+=1440;
  return Math.round(mins/6)/10;
}
function calcShiftPay(shift,rate) {
  const h=shift.hours;
  if (shift.type==='overtime') return h*rate*1.5;
  if (shift.type==='holiday') return h*rate*2;
  if (shift.type==='differential') return h*(rate+rate*0.1);
  return h*rate;
}

function addShift() {
  const date=document.getElementById('shiftDate').value;
  const type=document.getElementById('shiftType').value;
  const start=document.getElementById('shiftStart').value;
  const end=document.getElementById('shiftEnd').value;
  const route=document.getElementById('shiftRoute').value.trim();
  const notes=document.getElementById('shiftNotes').value.trim();
  if (!date||!start||!end) { showToast('Please fill date and times'); return; }
  const hours=calcHours(start,end);
  const pay=calcShiftPay({type,hours},currentUser.rate);
  const d=getUserData(currentUser.id);
  d.shifts.unshift({id:Date.now(),date,type,start,end,hours,pay,route,notes});
  saveUserData(currentUser.id,d);
  closeModal('shiftModal');
  document.getElementById('shiftNotes').value='';
  document.getElementById('shiftRoute').value='';
  showToast('✅ Shift logged!');
  refreshAll();
}

function deleteShift(id) {
  const d=getUserData(currentUser.id);
  d.shifts=d.shifts.filter(s=>s.id!==id);
  saveUserData(currentUser.id,d);
  showToast('Shift deleted');
  refreshAll();
}

function typeLabel(type) { return {regular:'Regular',overtime:'Overtime',holiday:'Holiday',differential:'Night Diff'}[type]||type; }
function typeTagClass(type) { return {regular:'tag-regular',overtime:'tag-overtime',holiday:'tag-holiday',differential:'tag-differential'}[type]||'tag-regular'; }

function renderShiftItem(s) {
  const d=new Date(s.date+'T12:00:00');
  const dateStr=d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
  return `<div class="shift-item"><div class="shift-left"><div class="shift-date">${dateStr}</div><div><span class="tag ${typeTagClass(s.type)}">${typeLabel(s.type)}</span></div><div class="shift-hours">${s.start}–${s.end} • ${s.hours}h${s.route?' • '+s.route:''}</div></div><div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px"><div class="shift-pay">$${s.pay.toFixed(2)}</div><button class="delete-btn" onclick="deleteShift(${s.id})">🗑️</button></div></div>`;
}

function addTask() {
  const text=document.getElementById('taskText').value.trim();
  const priority=document.getElementById('taskPriority').value;
  const due=document.getElementById('taskDue').value;
  if (!text) { showToast('Enter a task'); return; }
  const d=getUserData(currentUser.id);
  d.tasks.unshift({id:Date.now(),text,priority,due,done:false});
  saveUserData(currentUser.id,d);
  closeModal('taskModal');
  document.getElementById('taskText').value='';
  document.getElementById('taskDue').value='';
  showToast('✅ Task added!');
  renderTasks();
}

function toggleTask(id) { const d=getUserData(currentUser.id); const t=d.tasks.find(t=>t.id===id); if(t) t.done=!t.done; saveUserData(currentUser.id,d); renderTasks(); }
function deleteTask(id) { const d=getUserData(currentUser.id); d.tasks=d.tasks.filter(t=>t.id!==id); saveUserData(currentUser.id,d); renderTasks(); }

function renderTasks() {
  const d=getUserData(currentUser.id);
  const el=document.getElementById('tasksList');
  document.getElementById('taskCount').textContent=d.tasks.filter(t=>!t.done).length;
  if (!d.tasks.length) { el.innerHTML='<div class="empty-state"><div class="icon">✅</div><p>No tasks yet. Tap + to add one.</p></div>'; return; }
  el.innerHTML=d.tasks.map(t=>`<div class="task-item"><div class="task-check ${t.done?'done':''}" onclick="toggleTask(${t.id})">${t.done?'✓':''}</div><div style="flex:1"><div class="task-text ${t.done?'done':''}">${t.priority} ${t.text}</div>${t.due?`<div style="font-size:12px;color:var(--text2);margin-top:2px">Due: ${new Date(t.due+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'})}</div>`:''}</div><button class="delete-btn" onclick="deleteTask(${t.id})">🗑️</button></div>`).join('');
}

function renderCalendar() {
  const year=calDate.getFullYear(), month=calDate.getMonth();
  const monthNames=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('calMonth').textContent=monthNames[month]+' '+year;
  const d=getUserData(currentUser.id);
  const shiftDates={};
  d.shifts.forEach(s=>{shiftDates[s.date]=s.type;});
  const grid=document.getElementById('calGrid');
  let html=['Su','Mo','Tu','We','Th','Fr','Sa'].map(d=>`<div class="cal-day-name">${d}</div>`).join('');
  const firstDay=new Date(year,month,1).getDay();
  const daysInMonth=new Date(year,month+1,0).getDate();
  const today=new Date();
  for (let i=0;i<firstDay;i++) html+='<div class="cal-day empty"></div>';
  for (let day=1;day<=daysInMonth;day++) {
    const dateStr=`${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const isToday=today.getFullYear()===year&&today.getMonth()===month&&today.getDate()===day;
    const st=shiftDates[dateStr];
    const cls=['cal-day',isToday?'today':'',st?'has-shift':'',st==='overtime'?'ot':'',st==='holiday'?'holiday':''].filter(Boolean).join(' ');
    html+=`<div class="${cls}" onclick="showCalDay('${dateStr}')">${day}</div>`;
  }
  grid.innerHTML=html;
}

function showCalDay(dateStr) {
  const d=getUserData(currentUser.id);
  const shifts=d.shifts.filter(s=>s.date===dateStr);
  const dt=new Date(dateStr+'T12:00:00');
  document.getElementById('calDayTitle').textContent=dt.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
  document.getElementById('calDayShifts').innerHTML=shifts.length?shifts.map(renderShiftItem).join(''):'<div style="color:var(--text2);font-size:14px;padding:12px 0">No shifts on this day.</div>';
  document.getElementById('calDayDetail').style.display='block';
}

function prevMonth() { calDate.setMonth(calDate.getMonth()-1); renderCalendar(); document.getElementById('calDayDetail').style.display='none'; }
function nextMonth() { calDate.setMonth(calDate.getMonth()+1); renderCalendar(); document.getElementById('calDayDetail').style.display='none'; }

function getPayPeriodShifts(period) {
  const d=getUserData(currentUser.id);
  const now=new Date();
  return d.shifts.filter(s=>{
    const sd=new Date(s.date+'T12:00:00');
    if (period==='week') { const ws=new Date(now); ws.setDate(now.getDate()-now.getDay()); return sd>=ws; }
    if (period==='month') return sd.getMonth()===now.getMonth()&&sd.getFullYear()===now.getFullYear();
    if (period==='year') return sd.getFullYear()===now.getFullYear();
    return true;
  });
}

function updatePayPage() {
  const period=document.getElementById('payPeriodSelect').value;
  const shifts=getPayPeriodShifts(period);
  let regH=0,regP=0,otH=0,otP=0,holP=0,diffP=0;
  shifts.forEach(s=>{
    if (s.type==='regular'){regH+=s.hours;regP+=s.pay;}
    else if (s.type==='overtime'){otH+=s.hours;otP+=s.pay;}
    else if (s.type==='holiday') holP+=s.pay;
    else if (s.type==='differential') diffP+=s.pay;
  });
  const uniformPer=period==='year'?1200:period==='month'?100:period==='week'?23.08:1200;
  const total=regP+otP+holP+diffP+uniformPer;
  document.getElementById('payRegHours').textContent=regH.toFixed(1)+'h';
  document.getElementById('payRegPay').textContent='$'+regP.toFixed(2);
  document.getElementById('payOTHours').textContent=otH.toFixed(1)+'h';
  document.getElementById('payOTPay').textContent='$'+otP.toFixed(2);
  document.getElementById('payHolidayPay').textContent='$'+holP.toFixed(2);
  document.getElementById('payDiffPay').textContent='$'+diffP.toFixed(2);
  document.getElementById('payUniform').textContent='$'+uniformPer.toFixed(2);
  document.getElementById('payTotal').textContent='$'+total.toFixed(2);
}

function refreshAll() {
  const d=getUserData(currentUser.id);
  const now=new Date();
  const ws=new Date(now); ws.setDate(now.getDate()-now.getDay());
  const weekShifts=d.shifts.filter(s=>new Date(s.date+'T12:00:00')>=ws);
  const monthShifts=d.shifts.filter(s=>{const sd=new Date(s.date+'T12:00:00');return sd.getMonth()===now.getMonth()&&sd.getFullYear()===now.getFullYear();});
  document.getElementById('weekHours').textContent=weekShifts.reduce((a,s)=>a+s.hours,0).toFixed(1)+'h';
  document.getElementById('weekOT').textContent=weekShifts.filter(s=>s.type==='overtime').reduce((a,s)=>a+s.hours,0).toFixed(1)+'h overtime';
  document.getElementById('weekPay').textContent='$'+weekShifts.reduce((a,s)=>a+s.pay,0).toFixed(0);
  document.getElementById('monthHours').textContent=monthShifts.reduce((a,s)=>a+s.hours,0).toFixed(1)+'h';
  document.getElementById('monthPay').textContent='$'+monthShifts.reduce((a,s)=>a+s.pay,0).toFixed(0);
  document.getElementById('monthShifts').textContent=monthShifts.length;
  const recent=d.shifts.slice(0,5);
  document.getElementById('recentShifts').innerHTML=recent.length?recent.map(renderShiftItem).join(''):'<div class="empty-state"><div class="icon">📋</div><p>No shifts logged yet. Tap + to add your first shift.</p></div>';
  document.getElementById('shiftCount').textContent=d.shifts.length;
  document.getElementById('shiftsList').innerHTML=d.shifts.length?d.shifts.map(renderShiftItem).join(''):'<div class="empty-state"><div class="icon">🕐</div><p>No shifts yet. Tap + to log a shift.</p></div>';
  document.getElementById('profileShiftTotal').textContent=d.shifts.length;
  renderTasks();
}

function updateRate() {
  const r=parseFloat(document.getElementById('updateRate').value);
  if (!r||r<=0) { showToast('Enter a valid rate'); return; }
  const users=getUsers(); users[currentUser.id].rate=r; saveUsers(users); currentUser.rate=r;
  document.getElementById('profileRate').textContent='$'+r.toFixed(2)+'/hr';
  document.getElementById('baseRateDisplay').textContent='$'+r.toFixed(2)+'/hr';
  document.getElementById('otRateDisplay').textContent='$'+(r*1.5).toFixed(2);
  document.getElementById('holidayRateDisplay').textContent='$'+(r*2).toFixed(2);
  document.getElementById('updateRate').value='';
  showToast('Rate updated!');
}

function showToast(msg) { const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2500); }

window.addEventListener('click',e=>{if(e.target.classList.contains('modal-overlay'))e.target.classList.remove('open');});

const session=localStorage.getItem('dsny_session');
if (session) { const users=getUsers(); if(users[session]){currentUser=users[session];startApp();} }
</script>
</body>
</html>
